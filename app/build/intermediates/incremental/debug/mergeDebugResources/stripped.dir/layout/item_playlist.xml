<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_md"
    android:paddingVertical="@dimen/spacing_sm">

    <ImageView
        android:id="@+id/ivPlaylistIcon"
        android:layout_width="@dimen/album_art_small"
        android:layout_height="@dimen/album_art_small"
        android:background="@drawable/bg_album_art_placeholder"
        android:contentDescription="Playlist"
        android:padding="@dimen/spacing_sm"
        android:scaleType="centerInside"
        android:src="@drawable/ic_music_note"
        app:tint="@color/green_primary"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:id="@+id/tvPlaylistName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_body" />

</LinearLayout>
