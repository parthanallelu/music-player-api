        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">@dimen/corner_radius_sm</item>
        <item name="cardElevation">0dp</item>
    </style>
    <style name="SubtitleText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="Theme.MusicPlayer" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
