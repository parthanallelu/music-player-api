        <item name="android:textSize">@dimen/text_header</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">@dimen/corner_radius_xl</item>
    </style>
